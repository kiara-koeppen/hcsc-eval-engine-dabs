---
title: "MODULAR — config-driven BRANCH: standard for_each loop + a separate branch per LME model"
---
flowchart TD
  classDef cond fill:#FDEBD0,stroke:#B9770E,color:#7E5109,font-weight:bold;
  classDef nb fill:#E8F6F3,stroke:#148F77,color:#0E6251;
  classDef leaf fill:#FEF9E7,stroke:#B7950B,color:#7D6608;
  classDef ctrl fill:#EBF5FB,stroke:#2E86C1,color:#1B4F72,font-weight:bold;

  CFG["study_config_modular<br/><i>model_family = standard | lme_mixed | lme_growth | ...</i>"]:::ctrl --> LC
  LC["load_config_branched<br/><i>split + set branch flags</i>"]:::ctrl

  LC --> BS{{"branch:<br/>standard?"}}:::cond
  LC --> BM{{"branch:<br/>lme_mixed?"}}:::cond
  LC --> BG{{"branch:<br/>lme_growth?"}}:::cond

  %% standard family: shared for_each loop
  BS -->|true| FES["for_each(standard studies)"]:::ctrl
  subgraph RS["run_study_modular  (shared standard pipeline)"]
    direction LR
    F["dispatch_feature"]:::nb --> Q{{"gate"}}:::cond
    Q -->|pass| M["dispatch_matching"]:::nb --> MD["dispatch_model"]:::nb --> I["insights"]:::nb
  end
  FES --> F
  MD -. "config-named leaf" .-> SL["model_att / model_did /<br/>matching_stratified ..."]:::leaf

  %% LME model 1: its OWN branch + notebooks (no loop)
  BM -->|true| RM
  subgraph RM["run_lme_mixed  (its OWN notebooks)"]
    direction LR
    F1["feature_lme_mixed"]:::leaf --> Q1{{"gate"}}:::cond
    Q1 -->|pass| M1["matching_lme_mixed"]:::leaf --> D1["model_lme_mixed"]:::leaf --> I1["insights"]:::nb
  end

  %% LME model 2: its OWN branch + notebooks (no loop)
  BG -->|true| RG
  subgraph RG["run_lme_growth  (its OWN notebooks)"]
    direction LR
    F2["feature_lme_growth"]:::leaf --> Q2{{"gate"}}:::cond
    Q2 -->|pass| M2["matching_lme_growth"]:::leaf --> D2["model_lme_growth"]:::leaf --> I2["insights"]:::nb
  end

  N["The config DECIDES, then the job BRANCHES. Standard models (ATT/ATE/DID/pre-post) share one<br/>pipeline and fan out with for_each. Each structurally-different LME model is its OWN branch with<br/>its OWN feature/matching/model notebooks, NO loop, so each can diverge freely. Add another such<br/>model = add its rows + a branch. Add a standard model = a leaf notebook + a config row."]:::ctrl
